<Window x:Class="LogicCalculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LogicCalculator"
        Title="Logic Calculator" Height="500" Width="400"
        MinWidth="350" MinHeight="450"
        WindowStartupLocation="CenterScreen">
    
    <Window.DataContext>
        <local:CalculatorViewModel/>
    </Window.DataContext>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Display -->
        <Border Grid.Row="0" Background="#F5F5F5" BorderBrush="#DDD" BorderThickness="1" 
                CornerRadius="5" Margin="0,0,0,10" Padding="10">
            <TextBox Text="{Binding DisplayText, UpdateSourceTrigger=PropertyChanged}" 
                     FontSize="28" IsReadOnly="True" 
                     TextAlignment="Right" BorderThickness="0"
                     Background="Transparent"/>
        </Border>
        
        <!-- Buttons Grid -->
        <UniformGrid Grid.Row="1" Rows="6" Columns="4">
            <!-- Row 1 -->
            <Button Content="C" Command="{Binding ClearCommand}" Style="{StaticResource CalcButton}"/>
            <Button Content="DEL" Command="{Binding DeleteCommand}" Style="{StaticResource CalcButton}"/>
            <Button Content="(" Command="{Binding OperationCommand}" CommandParameter="(" Style="{StaticResource CalcButton}"/>
            <Button Content=")" Command="{Binding OperationCommand}" CommandParameter=")" Style="{StaticResource CalcButton}"/>
            
            <!-- Row 2 -->
            <Button Content="7" Command="{Binding DigitCommand}" CommandParameter="7" Style="{StaticResource CalcButton}"/>
            <Button Content="8" Command="{Binding DigitCommand}" CommandParameter="8" Style="{StaticResource CalcButton}"/>
            <Button Content="9" Command="{Binding DigitCommand}" CommandParameter="9" Style="{StaticResource CalcButton}"/>
            <Button Content="/" Command="{Binding OperationCommand}" CommandParameter="/" Style="{StaticResource OperatorButton}"/>
            
            <!-- Row 3 -->
            <Button Content="4" Command="{Binding DigitCommand}" CommandParameter="4" Style="{StaticResource CalcButton}"/>
            <Button Content="5" Command="{Binding DigitCommand}" CommandParameter="5" Style="{StaticResource CalcButton}"/>
            <Button Content="6" Command="{Binding DigitCommand}" CommandParameter="6" Style="{StaticResource CalcButton}"/>
            <Button Content="*" Command="{Binding OperationCommand}" CommandParameter="*" Style="{StaticResource OperatorButton}"/>
            
            <!-- Row 4 -->
            <Button Content="1" Command="{Binding DigitCommand}" CommandParameter="1" Style="{StaticResource CalcButton}"/>
            <Button Content="2" Command="{Binding DigitCommand}" CommandParameter="2" Style="{StaticResource CalcButton}"/>
            <Button Content="3" Command="{Binding DigitCommand}" CommandParameter="3" Style="{StaticResource CalcButton}"/>
            <Button Content="-" Command="{Binding OperationCommand}" CommandParameter="-" Style="{StaticResource OperatorButton}"/>
            
            <!-- Row 5 -->
            <Button Content="0" Command="{Binding DigitCommand}" CommandParameter="0" Style="{StaticResource CalcButton}"/>
            <Button Content="." Command="{Binding OperationCommand}" CommandParameter="." Style="{StaticResource CalcButton}"/>
            <Button Content="AND" Command="{Binding OperationCommand}" CommandParameter="&&" Style="{StaticResource LogicButton}"/>
            <Button Content="+" Command="{Binding OperationCommand}" CommandParameter="+" Style="{StaticResource OperatorButton}"/>
            
            <!-- Row 6 -->
            <Button Content="OR" Command="{Binding OperationCommand}" CommandParameter="||" Style="{StaticResource LogicButton}"/>
            <Button Content="NOT" Command="{Binding OperationCommand}" CommandParameter="!" Style="{StaticResource LogicButton}"/>
            <Button Content="XOR" Command="{Binding OperationCommand}" CommandParameter="^" Style="{StaticResource LogicButton}"/>
            <Button Content="=" Command="{Binding EqualsCommand}" Style="{StaticResource EqualsButton}"/>
        </UniformGrid>
    </Grid>
    
    <Window.Resources>
        <!-- Стили кнопок -->
        <Style x:Key="CalcButton" TargetType="Button">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Background" Value="#FFF"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
        </Style>
        
        <Style x:Key="OperatorButton" BasedOn="{StaticResource CalcButton}" TargetType="Button">
            <Setter Property="Background" Value="#E0E0E0"/>
        </Style>
        
        <Style x:Key="LogicButton" BasedOn="{StaticResource CalcButton}" TargetType="Button">
            <Setter Property="Background" Value="#E3F2FD"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        
        <Style x:Key="EqualsButton" BasedOn="{StaticResource CalcButton}" TargetType="Button">
            <Setter Property="Background" Value="#FFD700"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </Window.Resources>
</Window>
